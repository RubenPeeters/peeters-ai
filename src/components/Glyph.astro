---
export type GlyphName = 'portrait' | 'mortarboard' | 'leaf' | 'kgraph' | 'shapes' | 'column' | 'person' | 'page' | 'code' | 'envelope';

type Props = { name: GlyphName };
const { name } = Astro.props;
---
{name === 'portrait' && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="10" r="4.5" />
    <path d="M4 21c0-4 3.5-7 8-7s8 3 8 7" />
  </svg>
)}
{name === 'mortarboard' && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <polygon points="2 10 12 5 22 10 12 15 2 10" />
    <path d="M7 12.5v3.5c0 1.6 5 2.5 5 2.5s5-0.9 5-2.5v-3.5" />
    <path d="M20 10.5v5" />
  </svg>
)}
{name === 'leaf' && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M5 19c0-9 5-15 14-15-1 9-5 14-14 15z" />
    <path d="M5 19l8-8" />
  </svg>
)}
{name === 'kgraph' && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="6" cy="7" r="2" />
    <circle cx="18" cy="7" r="2" />
    <circle cx="12" cy="18" r="2" />
    <line x1="7.6" y1="8" x2="11" y2="16.4" />
    <line x1="16.4" y1="8" x2="13" y2="16.4" />
    <line x1="8" y1="7" x2="16" y2="7" />
  </svg>
)}
{name === 'shapes' && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="9" cy="13" r="5" />
    <rect x="10" y="5" width="10" height="10" />
  </svg>
)}
{name === 'column' && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="4" y="5" width="16" height="2.5" rx="0.5" />
    <rect x="4" y="16.5" width="16" height="2.5" rx="0.5" />
    <line x1="7" y1="7.5" x2="7" y2="16.5" />
    <line x1="12" y1="7.5" x2="12" y2="16.5" />
    <line x1="17" y1="7.5" x2="17" y2="16.5" />
  </svg>
)}
{name === 'person' && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="8" r="3.5" />
    <path d="M5 21v-1.5a4 4 0 0 1 4-4h6a4 4 0 0 1 4 4V21" />
  </svg>
)}
{name === 'page' && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="5" y="3" width="14" height="18" rx="1.5" />
    <line x1="8" y1="8" x2="16" y2="8" />
    <line x1="8" y1="12" x2="16" y2="12" />
    <line x1="8" y1="16" x2="13" y2="16" />
  </svg>
)}
{name === 'code' && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <polyline points="9 7 4 12 9 17" />
    <polyline points="15 7 20 12 15 17" />
  </svg>
)}
{name === 'envelope' && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="3" y="5" width="18" height="14" rx="1.5" />
    <polyline points="3 7 12 13 21 7" />
  </svg>
)}
