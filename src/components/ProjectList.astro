---
import { getCollection } from 'astro:content';
import { t, type Locale } from '~/i18n/strings';

type Props = { locale: Locale };
const { locale } = Astro.props;
const s = t(locale).projects;

const projects = await getCollection('projects');
const sorted = [...projects].sort((a, b) => b.data.sortKey - a.data.sortKey);
---
<ol class="projects">
  {sorted.map((project) => {
    const { title, description, repo, demo, year, tags } = project.data;
    return (
      <li class="project">
        <p class="meta">
          <span class="year">{year}</span>
          {tags.map((tag) => <span class="tag">{tag}</span>)}
        </p>
        <h3 class="title">{title}</h3>
        <p class="desc">{description[locale]}</p>
        <p class="links">
          {repo && (
            <a href={repo} class="ext" rel="noopener">{s.labels.repo}</a>
          )}
          {demo && (
            <a href={demo} class="ext" rel="noopener">{s.labels.demo}</a>
          )}
        </p>
      </li>
    );
  })}
</ol>

<style>
  .projects {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-48);
  }
  .project {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }
  .meta {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-12);
    font-family: var(--font-mono);
    font-size: var(--text-mono);
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    text-transform: uppercase;
    margin: 0;
  }
  .year { color: var(--color-text); font-weight: 500; }
  .tag::before { content: '· '; opacity: 0.5; }
  .meta .tag:first-of-type::before { content: ''; }
  .title {
    font-family: var(--font-sans);
    font-size: 1.375rem;
    line-height: 1.25;
    letter-spacing: -0.01em;
    font-weight: 500;
    margin: var(--space-4) 0 var(--space-4);
  }
  .desc {
    color: var(--color-text);
  }
  .links {
    display: flex;
    gap: var(--space-24);
    font-size: var(--text-small);
    margin: 0;
  }
</style>
