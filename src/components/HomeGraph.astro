---
import { t, pathFor, type Locale } from '~/i18n/strings';
import Glyph, { type GlyphName } from '~/components/Glyph.astro';

type Props = { locale: Locale };
const { locale } = Astro.props;
const s = t(locale);
const g = s.graph;

/*
  Node coordinates are in a 1000×600 viewBox. The same viewBox drives the
  SVG edges layer underneath. JS may nudge positions every frame, so the
  CSS variables --cx/--cy are the single source of truth at runtime.
  The center node is pinned (it's the anchor); everything else drifts.
*/
type NodeKind = 'center' | 'chip' | 'link';
type NodeDef = {
  id: string;
  kind: NodeKind;
  label: string;
  glyph: GlyphName;
  href?: string;
  section?: string;
  hx: number;
  hy: number;
};

const nodes: NodeDef[] = [
  { id: 'center',       kind: 'center', label: g.centerName,        glyph: 'portrait',    hx: 500, hy: 300 },
  { id: 'role',         kind: 'chip',   label: g.chips.role,        glyph: 'mortarboard', hx: 500, hy: 72  },
  { id: 'affiliation',  kind: 'chip',   label: g.chips.affiliation, glyph: 'leaf',        hx: 780, hy: 180 },
  { id: 'kgs',          kind: 'chip',   label: g.chips.interestKgs, glyph: 'kgraph',      hx: 730, hy: 450 },
  { id: 'mmml',         kind: 'chip',   label: g.chips.interestMmml,glyph: 'shapes',      hx: 270, hy: 450 },
  { id: 'ch',           kind: 'chip',   label: g.chips.interestCh,  glyph: 'column',      hx: 220, hy: 180 },
  { id: 'about',        kind: 'link',   label: s.about.title,       glyph: 'person',      href: pathFor('about', locale),    section: 'var(--color-section-about)',    hx: 900, hy: 48 },
  { id: 'research',     kind: 'link',   label: s.research.title,    glyph: 'page',        href: pathFor('research', locale), section: 'var(--color-section-research)', hx: 900, hy: 552 },
  { id: 'projects',     kind: 'link',   label: s.projects.title,    glyph: 'code',        href: pathFor('projects', locale), section: 'var(--color-section-projects)', hx: 100, hy: 552 },
  { id: 'contact',      kind: 'link',   label: s.contact.title,     glyph: 'envelope',    href: pathFor('contact', locale),  section: 'var(--color-section-contact)',  hx: 100, hy: 48  },
];

const edges = nodes.slice(1).map((n) => ({ from: 'center', to: n.id }));

const nodesPayload = nodes.map((n) => ({ id: n.id, hx: n.hx, hy: n.hy }));
---

<section class="graph-wrap" aria-label={g.ariaLabel}>
  <div
    class="graph"
    data-graph
    data-graph-nodes={JSON.stringify(nodesPayload)}
    data-graph-edges={JSON.stringify(edges)}
  >
    <svg
      class="graph-edges"
      viewBox="0 0 1000 600"
      preserveAspectRatio="none"
      aria-hidden="true"
    >
      {edges.map((e) => (
        <line data-edge-from={e.from} data-edge-to={e.to} class="edge" />
      ))}
    </svg>

    {nodes.map((n) => {
      const Tag = n.kind === 'link' ? 'a' : n.kind === 'center' ? 'h1' : 'span';
      const linkProps = n.kind === 'link' ? { href: n.href } : {};
      const ariaLabel = n.kind === 'link' ? n.label : undefined;
      return (
        <Tag
          class:list={[
            'node',
            n.kind === 'center' && 'node-center',
            n.kind === 'chip' && 'node-chip',
            n.kind === 'link' && 'node-link',
          ]}
          data-node-id={n.id}
          data-node-kind={n.kind}
          style={`--cx:${n.hx / 10}%;--cy:${n.hy / 6}%${n.section ? `;--section:${n.section}` : ''}`}
          aria-label={ariaLabel}
          {...linkProps}
        >
          {n.kind !== 'center' && (
            <span class="node-glyph" aria-hidden="true">
              <Glyph name={n.glyph} />
            </span>
          )}
          <span class="node-label">{n.label}</span>
        </Tag>
      );
    })}
  </div>

  <h2 class="visually-hidden" id="graph-fallback-heading">{g.listFallbackHeading}</h2>
  <ul class="visually-hidden" aria-labelledby="graph-fallback-heading">
    {nodes.filter((n) => n.kind === 'link').map((n) => (
      <li><a href={n.href}>{n.label}</a></li>
    ))}
  </ul>
</section>

<style>
  .graph-wrap {
    width: min(76rem, 94vw);
    margin-inline: auto;
    padding-block: var(--space-32) var(--space-64);
  }

  .graph {
    position: relative;
    aspect-ratio: 5 / 3;
    width: 100%;
    touch-action: none;
  }

  .graph-edges {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    /*
      Edges fade in after nodes have flown out and roughly settled. The
      delay matches the time it takes the impulse to carry the farthest
      corner-link node to its home position.
    */
    opacity: 0;
    transition: opacity 1100ms var(--ease) 1300ms;
  }
  .graph.is-loaded .graph-edges {
    opacity: 1;
  }
  .edge {
    stroke: var(--color-border);
    stroke-width: 1;
    opacity: 0.55;
    vector-effect: non-scaling-stroke;
  }

  .node {
    position: absolute;
    left: var(--cx);
    top: var(--cy);
    transform: translate(-50%, -50%);
    z-index: 1;
    /*
      Glyph stays visible always; label hangs below the glyph and fades in
      on hover. Wrapper sizes to the glyph so edges and physics still aim at
      the icon center, not at the gap below it.
    */
    cursor: grab;
    user-select: none;
    -webkit-user-select: none;
    color: var(--color-text);
  }
  .node:active { cursor: grabbing; }

  .node-glyph {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
  }
  /*
    Two node tiers with a wide air gap between glyph and border. SVG is
    roughly a quarter of the circle so the icon floats in cream space.
  */
  .node-chip .node-glyph {
    width: 4.25rem;
    height: 4.25rem;
  }
  /*
    Glyph SVGs live in a separate Astro component, so their attributes are
    outside this file's scope. :global() breaks the scope just for the svg
    selector so the size actually applies.
  */
  .node-chip .node-glyph :global(svg) {
    width: 2.5rem;
    height: 2.5rem;
  }
  .node-link .node-glyph {
    width: 6rem;
    height: 6rem;
  }
  .node-link .node-glyph :global(svg) {
    width: 3.5rem;
    height: 3.5rem;
  }

  .node-label {
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 50%;
    white-space: nowrap;
    opacity: 0;
    transform: translate(-50%, 0.25rem);
    transition: opacity var(--dur) var(--ease), transform var(--dur) var(--ease);
    pointer-events: none;
  }

  /* Reveal label on hover / focus / drag-pin */
  .node:hover .node-label,
  .node:focus-visible .node-label,
  .node.is-revealed .node-label {
    opacity: 1;
    transform: translate(-50%, 0);
  }

  /*
    Center node — pinned anchor, no glyph, label rendered directly as a
    big h1 with the cursor-follow text glow. Always visible; no hover swap.
    Scales + fades in on load, before the rest of the graph blooms outward.
  */
  .node-center {
    margin: 0;
    cursor: default;
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.94);
    transition: opacity 950ms var(--ease), transform 950ms var(--ease);
  }
  .node-center:active { cursor: default; }
  .graph.is-loaded .node-center {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }
  .node-center .node-label {
    position: static;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(2.5rem, 1.8rem + 3vw, 4.25rem);
    line-height: 1.05;
    letter-spacing: -0.025em;
    padding: var(--space-8) var(--space-16);
    opacity: 1;
    transform: none;
    pointer-events: auto;
    background-image: radial-gradient(
      circle at var(--x, -100%) var(--y, -100%),
      color-mix(in srgb, var(--color-tertiary) calc(var(--glow-opacity, 0) * 100%), var(--color-text)) 0%,
      color-mix(in srgb, var(--color-tertiary) calc(var(--glow-opacity, 0) * 100%), var(--color-text)) var(--pulse-radius, 20%),
      var(--color-text) 60%
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  /*
    Chip and link wrappers fade in slightly after the center settles. The
    physics impulse carries them outward visually; the fade just keeps the
    initial frame clean instead of all icons stacked on the title.
  */
  .node-chip,
  .node-link {
    opacity: 0;
    transition: opacity 900ms var(--ease) 400ms;
  }
  .graph.is-loaded .node-chip,
  .graph.is-loaded .node-link {
    opacity: 1;
  }

  .node-chip .node-label {
    font-size: var(--text-body);
    color: var(--color-text-muted);
  }
  .node-link {
    text-decoration: none;
    border-bottom: none;
  }
  .node-link .node-label {
    font-size: var(--text-body);
    font-weight: 500;
    color: var(--color-text-muted);
  }
  /*
    Per-link section disc — sized to the glyph, offset down-right at rest.
    On hover it slides into alignment behind the glyph and darkens slightly.
    No shape morph; the label appears separately below the node.
  */
  .node-link::before {
    content: '';
    position: absolute;
    width: 6rem;
    height: 6rem;
    border-radius: 50%;
    background-color: var(--section, var(--color-accent));
    opacity: 0.32;
    top: 50%;
    left: 50%;
    transform: translate(calc(-50% + 0.125rem), calc(-50% + 0.125rem));
    transition: transform var(--dur) var(--ease), opacity var(--dur) var(--ease);
    pointer-events: none;
    z-index: 0;
  }
  .node-link .node-glyph {
    position: relative;
    z-index: 1;
  }
  .node-link:hover::before,
  .node-link:focus-visible::before {
    transform: translate(-50%, -50%);
    opacity: 0.5;
  }
  .node-link:focus-visible {
    outline: 2px solid var(--section, var(--color-accent));
    outline-offset: 6px;
    border-radius: 999px;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /*
    Mobile — collapse to a vertical stack. Disable physics layout, hide edges,
    show labels permanently (no hover on touch).
  */
  @media (max-width: 640px) {
    .graph {
      aspect-ratio: auto;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-16);
      touch-action: auto;
    }
    .graph-edges { display: none; }
    .node {
      position: static;
      transform: none;
      cursor: default;
      display: flex;
      align-items: center;
      gap: var(--space-16);
    }
    .node-label {
      position: static;
      transition: none;
      transform: none;
      opacity: 1;
      pointer-events: auto;
    }
    .node-link::before { display: none; }
    .node-center .node-label {
      font-size: clamp(2rem, 7vw, 2.75rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .node-label,
    .node-link::before,
    .node-center,
    .node-chip,
    .node-link,
    .graph-edges {
      transition: none;
    }
    /*
      Skip the load fade entirely — render at final state regardless of
      whether the class has been added yet.
    */
    .node-center,
    .node-chip,
    .node-link,
    .graph-edges {
      opacity: 1;
    }
    .node-center {
      transform: translate(-50%, -50%);
    }
  }
</style>

<script>
  type NodeState = {
    id: string;
    el: HTMLElement;
    kind: 'center' | 'chip' | 'link';
    hx: number; hy: number;     // home position (viewBox units, 0..1000 x 0..600)
    x: number;  y: number;      // current position
    vx: number; vy: number;     // velocity
    pinned: boolean;
  };

  const graphEl = document.querySelector<HTMLElement>('[data-graph]');
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (graphEl) {
    const graph = graphEl;
    const nodeDefs: { id: string; hx: number; hy: number }[] = JSON.parse(
      graph.dataset.graphNodes || '[]'
    );
    const edgeDefs: { from: string; to: string }[] = JSON.parse(
      graph.dataset.graphEdges || '[]'
    );

    const nodes: NodeState[] = nodeDefs.map((d) => {
      const el = graph.querySelector<HTMLElement>(`[data-node-id="${d.id}"]`)!;
      const kind = (el.dataset.nodeKind as NodeState['kind']) ?? 'chip';
      /*
        Load animation: non-center nodes start collapsed onto the center
        (with a tiny jitter so pairwise repulsion has a defined direction)
        and get an outward impulse toward their home. Center stays at home.
      */
      const startAtHome = reduceMotion || kind === 'center';
      const x = startAtHome ? d.hx : 500 + (Math.random() - 0.5) * 8;
      const y = startAtHome ? d.hy : 300 + (Math.random() - 0.5) * 8;
      return {
        id: d.id,
        el,
        kind,
        hx: d.hx, hy: d.hy,
        x, y,
        vx: 0, vy: 0,
        // Center stays pinned permanently — it's the narrative anchor and
        // never drifts or accepts drag.
        pinned: kind === 'center',
      };
    });
    const byId = new Map(nodes.map((n) => [n.id, n]));

    const edgeEls = Array.from(
      graph.querySelectorAll<SVGLineElement>('.edge')
    );

    const center = byId.get('center');

    /* ---------- viewBox <-> screen px mapping for drag ---------- */
    const VB_W = 1000;
    const VB_H = 600;

    /* ---------- physics ---------- */
    const REPULSION = 60_000;
    const SPRING_K = 0.014;
    const REST = 280;            // resting edge length, viewBox units
    const HOME_K = 0.035;        // looser home pull — nodes can wander further
    const DAMPING = 0.93;        // higher retention → motion sustains
    const WIND = 32;             // stronger random impulse per frame
    const EDGE_INSET_CENTER = 180;
    const EDGE_INSET_NODE = 55;

    /*
      Outward fly-out kick. Velocity is proportional to displacement from
      center (v = Δ * rate), so corner link nodes leave fast and travel
      far while inner chips drift out gently. All nodes settle in roughly
      the same beat, but the corners arrive bigger.
    */
    if (!reduceMotion) {
      const FLYOUT_RATE = 3.5;
      nodes.forEach((n) => {
        if (n.pinned) return;
        n.vx = (n.hx - n.x) * FLYOUT_RATE;
        n.vy = (n.hy - n.y) * FLYOUT_RATE;
      });
    }

    function applyForces(dt: number) {
      // pairwise repulsion
      for (let i = 0; i < nodes.length; i++) {
        const a = nodes[i];
        if (a.pinned) continue;
        let fx = 0, fy = 0;
        for (let j = 0; j < nodes.length; j++) {
          if (i === j) continue;
          const b = nodes[j];
          const dx = a.x - b.x;
          const dy = a.y - b.y;
          const d2 = dx * dx + dy * dy + 100;
          const f = REPULSION / d2;
          const d = Math.sqrt(d2);
          fx += (dx / d) * f;
          fy += (dy / d) * f;
        }
        // home pull
        fx += (a.hx - a.x) * HOME_K;
        fy += (a.hy - a.y) * HOME_K;
        // wind
        fx += (Math.random() - 0.5) * WIND;
        fy += (Math.random() - 0.5) * WIND;

        a.vx = (a.vx + fx * dt) * DAMPING;
        a.vy = (a.vy + fy * dt) * DAMPING;
      }
      // edge springs — pull connected nodes toward rest length
      for (const e of edgeDefs) {
        const a = byId.get(e.from)!;
        const b = byId.get(e.to)!;
        const dx = b.x - a.x;
        const dy = b.y - a.y;
        const d = Math.hypot(dx, dy) || 0.001;
        const stretch = d - REST;
        const f = SPRING_K * stretch;
        const ux = dx / d;
        const uy = dy / d;
        if (!a.pinned) { a.vx += f * ux * dt; a.vy += f * uy * dt; }
        if (!b.pinned) { b.vx -= f * ux * dt; b.vy -= f * uy * dt; }
      }
      // integrate
      for (const n of nodes) {
        if (n.pinned) continue;
        n.x += n.vx * dt;
        n.y += n.vy * dt;
        // clamp inside viewBox with soft margins
        const m = 40;
        if (n.x < m)        { n.x = m;          n.vx = Math.abs(n.vx) * 0.5; }
        if (n.x > VB_W - m) { n.x = VB_W - m;   n.vx = -Math.abs(n.vx) * 0.5; }
        if (n.y < m)        { n.y = m;          n.vy = Math.abs(n.vy) * 0.5; }
        if (n.y > VB_H - m) { n.y = VB_H - m;   n.vy = -Math.abs(n.vy) * 0.5; }
      }
    }

    function render() {
      for (const n of nodes) {
        n.el.style.setProperty('--cx', `${n.x / 10}%`);
        n.el.style.setProperty('--cy', `${n.y / 6}%`);
      }
      const c = center!;
      for (let i = 0; i < edgeDefs.length; i++) {
        const e = edgeDefs[i];
        const a = byId.get(e.from)!;
        const b = byId.get(e.to)!;
        const dx = b.x - a.x;
        const dy = b.y - a.y;
        const len = Math.hypot(dx, dy) || 0.001;
        const ux = dx / len;
        const uy = dy / len;
        // shorter inset on the chip-side, larger on the center-side, so edges
        // meet labels rather than pierce them
        const insetA = a === c ? EDGE_INSET_CENTER : EDGE_INSET_NODE;
        const insetB = b === c ? EDGE_INSET_CENTER : EDGE_INSET_NODE;
        const ln = edgeEls[i];
        ln.setAttribute('x1', String(a.x + ux * insetA));
        ln.setAttribute('y1', String(a.y + uy * insetA));
        ln.setAttribute('x2', String(b.x - ux * insetB));
        ln.setAttribute('y2', String(b.y - uy * insetB));
      }
    }

    /* ---------- animation loop with idle sleep ---------- */
    let rafId: number | null = null;
    let lastT = performance.now();

    function tick(t: number) {
      const dt = Math.min(0.033, (t - lastT) / 1000);
      lastT = t;
      applyForces(dt);
      render();
      updateGlow();
      rafId = requestAnimationFrame(tick);
    }

    function start() {
      if (rafId !== null || reduceMotion) return;
      lastT = performance.now();
      rafId = requestAnimationFrame(tick);
    }

    // Initial render so positions are sane before first frame
    render();
    /*
      Trigger CSS load animation after first paint. Double rAF guarantees the
      initial transform state lands in the DOM before .is-loaded swaps in the
      final state, otherwise the transition is skipped.
    */
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        graph.classList.add('is-loaded');
      });
    });
    start();

    /* ---------- drag ---------- */
    function vbFromClient(clientX: number, clientY: number) {
      const r = graph.getBoundingClientRect();
      const x = ((clientX - r.left) / r.width) * VB_W;
      const y = ((clientY - r.top)  / r.height) * VB_H;
      return { x, y };
    }

    let dragNode: NodeState | null = null;
    let dragStart = { x: 0, y: 0 };
    let didDrag = false;
    const DRAG_THRESHOLD = 4; // px

    nodes.forEach((n) => {
      // Center is non-grabbable; skip drag wiring.
      if (n.kind === 'center') return;
      n.el.addEventListener('pointerdown', (e) => {
        // ignore non-primary buttons
        if (e.button !== 0 && e.pointerType === 'mouse') return;
        dragNode = n;
        n.pinned = true;
        n.vx = 0; n.vy = 0;
        dragStart = { x: e.clientX, y: e.clientY };
        didDrag = false;
        n.el.setPointerCapture(e.pointerId);
        start();
      });

      n.el.addEventListener('pointermove', (e) => {
        if (!dragNode || dragNode !== n) return;
        const dx = e.clientX - dragStart.x;
        const dy = e.clientY - dragStart.y;
        if (!didDrag && Math.hypot(dx, dy) > DRAG_THRESHOLD) didDrag = true;
        const p = vbFromClient(e.clientX, e.clientY);
        n.x = p.x; n.y = p.y;
      });

      const endDrag = (e: PointerEvent) => {
        if (!dragNode || dragNode !== n) return;
        n.pinned = false;
        n.el.releasePointerCapture(e.pointerId);
        dragNode = null;
      };
      n.el.addEventListener('pointerup', endDrag);
      n.el.addEventListener('pointercancel', endDrag);

      // Suppress link navigation when the user actually dragged.
      if (n.kind === 'link') {
        n.el.addEventListener('click', (e) => {
          if (didDrag) e.preventDefault();
        });
      }
    });

    /* ---------- center cursor-follow glow ---------- */
    const centerEl = center!.el;
    const centerLabel = centerEl.querySelector<HTMLElement>('.node-label')!;
    let glowAngle = 0;
    let glowOpacity = 0;
    let glowHovered = false;

    function updateGlow() {
      if (reduceMotion) return;
      if (glowHovered && glowOpacity < 1) glowOpacity = Math.min(1, glowOpacity + 0.1);
      else if (!glowHovered && glowOpacity > 0) glowOpacity = Math.max(0, glowOpacity - 0.05);
      centerLabel.style.setProperty('--glow-opacity', String(glowOpacity));
      glowAngle += 0.05;
      const pulse = Math.sin(glowAngle) * 5 + 20;
      centerLabel.style.setProperty('--pulse-radius', `${pulse}%`);
    }

    document.addEventListener('pointermove', (e) => {
      const r = centerLabel.getBoundingClientRect();
      centerLabel.style.setProperty('--x', `${e.clientX - r.left}px`);
      centerLabel.style.setProperty('--y', `${e.clientY - r.top}px`);
      glowHovered = true;
    });
    document.addEventListener('pointerleave', () => { glowHovered = false; });
  }
</script>
