---
import '~/styles/global.css';
import { t, pathFor, type Locale } from '~/i18n/strings';

type Props = {
  locale: Locale;
  title?: string;
  description?: string;
  path?: string;
};

const { locale, title, description, path = '' } = Astro.props;
const s = t(locale);

const pageTitle = title ? `${title} — ${s.siteName}` : s.siteName;
const pageDescription = description ?? s.tagline;

const otherLocale: Locale = locale === 'en' ? 'nl' : 'en';
const otherHref = pathFor(otherLocale, path);
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;1,6..72,400&family=Hanken+Grotesk:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap"
    />
    <link rel="alternate" hreflang={locale} href={Astro.url.href} />
    <link rel="alternate" hreflang={otherLocale} href={new URL(otherHref, Astro.site).href} />
  </head>
  <body>
    <header class="container site-header">
      <a href={pathFor(locale)} class="pill brand" aria-label={s.siteName}>RP</a>
      <nav aria-label={s.langSwitch.label} class="lang-switch">
        <a
          href={otherHref}
          hreflang={otherLocale}
          class="pill"
          aria-label={`${s.langSwitch.label}: ${s.langSwitch[otherLocale]}`}
        >
          {s.langSwitch[otherLocale]}
        </a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="container site-footer">
      <p>
        {s.footer.builtWith}{' '}
        <a href="https://github.com/RubenPeeters/peeters-ai" class="ext">{s.footer.source}</a>.
      </p>
    </footer>

    <style>
      .site-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-block: var(--space-32) var(--space-96);
        gap: var(--space-16);
      }
      .brand {
        font-weight: 500;
      }
      .lang-switch {
        display: flex;
        gap: var(--space-8);
      }
      .site-footer {
        padding-block: var(--space-48) var(--space-32);
        color: var(--color-text-muted);
        font-size: var(--text-small);
        border-top: 1px solid var(--color-border);
        margin-top: var(--space-96);
      }
      .site-footer p { max-width: none; }
    </style>
  </body>
</html>
