---
import Base from '~/layouts/Base.astro';
import ProjectList from '~/components/ProjectList.astro';
import { t } from '~/i18n/strings';

const locale = 'en' as const;
const s = t(locale);
---
<Base locale={locale} routeKey="projects" title={s.projects.title} description={s.projects.intro}>
  <article class="container projects-page">
    <p class="eyebrow">{s.projects.title}</p>
    <h1 class="intro">{s.projects.intro}</h1>

    <ProjectList locale={locale} />

    <p class="more">
      <a href="https://github.com/RubenPeeters" class="ext" rel="noopener">{s.projects.more}</a>
    </p>
  </article>

  <style>
    .projects-page {
      padding-block: var(--space-32) var(--space-96);
      display: flex;
      flex-direction: column;
      gap: var(--space-48);
    }
    .projects-page .eyebrow { margin: 0; }
    .intro {
      font-family: var(--font-serif);
      font-size: var(--text-tagline);
      line-height: 1.35;
      color: var(--color-text);
      max-width: 36ch;
    }
    .more {
      font-size: var(--text-small);
      color: var(--color-text-muted);
    }
  </style>
</Base>
