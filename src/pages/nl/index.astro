---
import Base from '~/layouts/Base.astro';
import { t } from '~/i18n/strings';

const locale = 'nl' as const;
const s = t(locale);
---
<Base locale={locale} routeKey="home">
  <section class="container hero">
    <p class="eyebrow">{s.eyebrow}</p>
    <h1>{s.siteName}</h1>
    <p class="tagline">
      {s.taglineParts.pre}<em>{s.taglineParts.em}</em>{s.taglineParts.post}
    </p>
  </section>

  <style>
    .hero { padding-block: var(--space-32) var(--space-96); }
    .eyebrow { margin-bottom: var(--space-24); }
    h1 { margin-bottom: var(--space-32); }
    .tagline {
      font-family: var(--font-serif);
      font-size: var(--text-tagline);
      line-height: 1.35;
      color: var(--color-text);
      max-width: 32ch;
    }
    .tagline em {
      font-style: italic;
      font-variation-settings: 'opsz' 18;
    }
  </style>
</Base>
