---
import Base from '~/layouts/Base.astro';
import { t } from '~/i18n/strings';

const locale = 'nl' as const;
const s = t(locale);
---
<Base locale={locale} routeKey="about" title={s.about.title} description={s.about.intro}>
  <article class="container about">
    <p class="eyebrow">{s.about.title}</p>
    <p class="intro">{s.about.intro}</p>

    <p class="currently">
      <span class="dot" aria-hidden="true"></span>
      {s.about.currently}
    </p>

    {s.about.paragraphs.map((para) => <p>{para}</p>)}
  </article>

  <style>
    .about {
      padding-block: var(--space-32) var(--space-96);
      display: flex;
      flex-direction: column;
      gap: var(--space-32);
    }
    .about .eyebrow { margin: 0; }
    .intro {
      font-family: var(--font-serif);
      font-size: var(--text-tagline);
      line-height: 1.35;
      color: var(--color-text);
      max-width: 36ch;
    }
    .currently {
      display: flex;
      align-items: baseline;
      gap: var(--space-12);
      color: var(--color-text-muted);
      font-size: var(--text-small);
    }
    .currently .dot {
      width: 0.5rem;
      height: 0.5rem;
      border-radius: 999px;
      background: var(--color-accent);
      flex-shrink: 0;
      transform: translateY(-0.05rem);
    }
  </style>
</Base>
