---
import Base from '~/layouts/Base.astro';
import PostList from '~/components/PostList.astro';
import { t } from '~/i18n/strings';

const locale = 'en' as const;
const s = t(locale);
---
<Base locale={locale} routeKey="blog" title={s.blog.title} description={s.blog.intro}>
  <article class="container blog-index">
    <p class="eyebrow">{s.blog.title}</p>
    <h1 class="intro">{s.blog.intro}</h1>

    <PostList locale={locale} />
  </article>

  <style>
    .blog-index {
      padding-block: var(--space-32) var(--space-96);
      display: flex;
      flex-direction: column;
      gap: var(--space-48);
    }
    .blog-index .eyebrow { margin: 0; }
    .intro {
      font-family: var(--font-sans);
      font-size: var(--text-tagline);
      line-height: 1.35;
      color: var(--color-text);
      max-width: 36ch;
    }
  </style>
</Base>
